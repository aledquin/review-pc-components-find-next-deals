# Copy to .env and fill in for local development.
# Never commit a real .env.

# --- Best Buy Developer API ---
# https://developer.bestbuy.com/
PCA_BESTBUY_API_KEY=

# --- Amazon Product Advertising API 5 ---
PCA_AMAZON_ACCESS_KEY=
PCA_AMAZON_SECRET_KEY=
PCA_AMAZON_ASSOC_TAG=
PCA_AMAZON_REGION=us-east-1

# --- eBay Browse API (OAuth2 client credentials) ---
PCA_EBAY_CLIENT_ID=
PCA_EBAY_CLIENT_SECRET=

# --- Keepa (optional premium) ---
PCA_KEEPA_API_KEY=

# --- Runtime ---
PCA_LOG_LEVEL=INFO
PCA_CACHE_DIR=
PCA_REPORT_DIR=
