# PC Upgrade Advisor - sample configuration.
#
# Copy this file to `.env` in the same directory as you run `pca` from,
# or set the same variables in your OS environment. Every setting is
# optional - the app works offline with the bundled default market if
# you leave every credential blank.
#
# Never commit a real `.env`. See docs/user-guide.md Section 2 for
# rotation, precedence, and per-UI reload instructions.

# =======================================================================
# Retailer credentials
#
# Missing/blank credentials make the corresponding adapter stay inert;
# the rest of the app keeps working. Run `pca doctor` to see which
# adapters are active and why.
# =======================================================================

# --- Best Buy Developer API (free, US-only, 50k req/day) ---
# Sign up: https://developer.bestbuy.com/
PCA_BESTBUY_API_KEY=

# --- Amazon Product Advertising API 5 (requires approved Associate) ---
# Portal: https://webservices.amazon.com/paapi5/documentation/
PCA_AMAZON_ACCESS_KEY=
PCA_AMAZON_SECRET_KEY=
PCA_AMAZON_ASSOC_TAG=
PCA_AMAZON_REGION=us-east-1

# --- eBay Browse API (OAuth2 client credentials) ---
# Same credentials drive both `ebay` and `ebay-sold` adapters.
# Portal: https://developer.ebay.com/
PCA_EBAY_CLIENT_ID=
PCA_EBAY_CLIENT_SECRET=

# --- Keepa (optional Amazon price-history premium) ---
# https://keepa.com
PCA_KEEPA_API_KEY=

# --- Newegg affiliate feed (local file only - no scraping) ---
# Absolute path to a CSV/TSV feed you download from the affiliate portal.
PCA_NEWEGG_FEED_PATH=

# =======================================================================
# Adapter selection / behaviour
# =======================================================================

# Comma-separated allow-list of adapters to instantiate.
# Leave empty (default) to use every adapter whose credentials are set.
# Example: PCA_ENABLE_ADAPTERS=bestbuy,ebay
PCA_ENABLE_ADAPTERS=

# Load third-party retailer plugins exposed as Python entry points.
PCA_ALLOW_PLUGINS=false

# Let scraping fallbacks run (opt-in - see ADR 0007).
PCA_ENABLE_SCRAPERS=false

# Per-request HTTP timeout used by the default httpx transport (seconds).
PCA_ADAPTER_HTTP_TIMEOUT=10.0

# =======================================================================
# Runtime
# =======================================================================

PCA_LOG_LEVEL=INFO

# Override the platform defaults if you want reports / cache elsewhere.
PCA_CACHE_DIR=
PCA_REPORT_DIR=
PCA_USER_DATA_DIR=

# Let OpenAIExplainer reach the cloud when PCA_OPENAI_API_KEY is set.
PCA_ALLOW_CLOUD_LLM=false
PCA_OPENAI_API_KEY=

# =======================================================================
# Deal ranker (advanced tuning; defaults calibrated against KGRs)
# =======================================================================

PCA_DEAL_WEIGHT_PRICE=0.5
PCA_DEAL_WEIGHT_REPUTATION=0.2
PCA_DEAL_WEIGHT_SHIPPING=0.1
PCA_DEAL_WEIGHT_WARRANTY=0.1
PCA_DEAL_WEIGHT_FRESHNESS=0.1
