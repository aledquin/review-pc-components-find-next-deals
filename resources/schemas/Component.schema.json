    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "specs": {
      "additionalProperties": true,
      "title": "Specs",
      "type": "object"
    },
    "vendor": {
      "minLength": 1,
      "title": "Vendor",
      "type": "string"
    }
