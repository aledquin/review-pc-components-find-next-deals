        "gpu",
        "ram",
        "motherboard",
        "storage",
        "psu",
        "cooler",
        "case",
        "peripheral",
        "os"
      ],
      "title": "ComponentKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
