<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PC Upgrade Advisor</title>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <script defer src="https://unpkg.com/alpinejs@3.13.5"></script>
  <style>
    :root {
      --bg: #0f1115;
      --panel: #171a21;
      --panel-2: #1f2330;
      --text: #e7ebf3;
      --muted: #9aa3b2;
      --accent: #6aa1ff;
      --accent-2: #8ad0a5;
      --danger: #ff6b6b;
      --border: #2a2f3d;
      --radius: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,.3), 0 8px 24px rgba(0,0,0,.2);
      --mono: ui-monospace, "Cascadia Code", "JetBrains Mono", Consolas, monospace;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f7f8fb;
        --panel: #ffffff;
        --panel-2: #f1f3f9;
        --text: #111420;
        --muted: #5a6473;
        --accent: #2b63d9;
        --accent-2: #2f8f5b;
        --danger: #c62828;
        --border: #d7dbe6;
        --shadow: 0 1px 2px rgba(20,30,60,.06), 0 6px 18px rgba(20,30,60,.08);
      }
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      margin: 0;
      font-family: -apple-system, "Segoe UI", Roboto, Inter, "Helvetica Neue", sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }
    header.topbar {
      display: flex; align-items: center; gap: .75rem;
      padding: .9rem 1.25rem;
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 10;
    }
    .logo {
      width: 28px; height: 28px; border-radius: 6px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: inline-flex; align-items: center; justify-content: center;
      color: white; font-weight: 700;
    }
    header h1 { font-size: 1.05rem; margin: 0; font-weight: 600; }
    header .muted { color: var(--muted); font-size: .85rem; margin-left: auto; }
    main {
      max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem;
      display: grid; grid-template-columns: 1fr; gap: 1.25rem;
    }
    @media (min-width: 960px) {
      main { grid-template-columns: 360px 1fr; }
      .col-span-2 { grid-column: 1 / -1; }
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .card-head {
      display: flex; align-items: center; gap: .5rem;
      padding: .9rem 1.1rem;
      border-bottom: 1px solid var(--border);
      background: var(--panel-2);
    }
    .card-head h2 { margin: 0; font-size: 1rem; font-weight: 600; letter-spacing: .02em; }
    .card-head .badge {
      margin-left: auto;
      font-size: .72rem; color: var(--muted);
      background: var(--bg); border: 1px solid var(--border);
      padding: .1rem .45rem; border-radius: 999px;
      font-family: var(--mono);
    }
    .card-body { padding: 1.1rem; }
    .form-row {
      display: grid; grid-template-columns: auto 1fr; gap: .5rem .75rem;
      align-items: center; margin-bottom: .6rem;
    }
    label { color: var(--muted); font-size: .85rem; }
    input, select, button {
      font: inherit; color: var(--text);
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 6px; padding: .45rem .6rem; min-width: 0;
    }
    input:focus, select:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
    button.primary {
      background: var(--accent); color: white; border-color: transparent;
      cursor: pointer; font-weight: 600;
    }
    button.primary:hover { filter: brightness(1.08); }
    button.ghost {
      background: transparent; color: var(--text); cursor: pointer;
    }
    button.ghost:hover { background: var(--panel-2); }
    button:disabled { opacity: .5; cursor: not-allowed; }
    .actions { display: flex; gap: .5rem; margin-top: .75rem; flex-wrap: wrap; }
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    th, td { padding: .5rem .6rem; text-align: left; border-bottom: 1px solid var(--border); }
    th { color: var(--muted); font-weight: 600; font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; }
    tbody tr:hover { background: var(--panel-2); }
    .num { font-family: var(--mono); text-align: right; }
    .muted { color: var(--muted); font-size: .9rem; }
    .totals {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: .75rem; margin-top: .75rem;
    }
    .totals .tile {
      background: var(--panel-2); border: 1px solid var(--border);
      border-radius: 8px; padding: .75rem;
    }
    .totals .tile .k { color: var(--muted); font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; }
    .totals .tile .v { font-size: 1.15rem; font-weight: 600; margin-top: .2rem; font-family: var(--mono); }
    .htmx-indicator { display: none; color: var(--muted); font-size: .85rem; }
    .htmx-request .htmx-indicator { display: inline; }
    .htmx-request.pending-hide { opacity: .4; pointer-events: none; }
    .pill-row { display: flex; flex-wrap: wrap; gap: .35rem; }
    .pill {
      display: inline-block; font-size: .72rem; color: var(--muted);
      border: 1px solid var(--border); background: var(--bg);
      border-radius: 999px; padding: .1rem .55rem; font-family: var(--mono);
    }
    .pill.warn { color: var(--danger); border-color: var(--danger); }
    details > summary { cursor: pointer; color: var(--muted); font-size: .85rem; }
    pre.json {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 6px; padding: .75rem; font-family: var(--mono);
      font-size: .8rem; max-height: 320px; overflow: auto; white-space: pre-wrap;
    }
    .kvs { display: grid; grid-template-columns: max-content 1fr; gap: .3rem .75rem; }
    .kvs dt { color: var(--muted); font-size: .82rem; }
    .kvs dd { margin: 0; font-family: var(--mono); font-size: .85rem; }
    /* Vertical spec list used by the Inventory table */
    .spec-list, .spec-diff {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: .2rem;
    }
    .spec-list li, .spec-diff li {
      display: flex; align-items: baseline; gap: .5rem;
      padding: .15rem 0;
      border-bottom: 1px dashed var(--border);
      font-size: .85rem;
    }
    .spec-list li:last-child, .spec-diff li:last-child { border-bottom: 0; }
    .spec-k {
      color: var(--muted);
      min-width: 9rem; flex: 0 0 auto;
      text-transform: capitalize;
    }
    .spec-v {
      font-family: var(--mono);
      color: var(--text); word-break: break-word;
    }
    .spec-diff .spec-from {
      color: var(--muted); text-decoration: line-through;
    }
    .spec-diff .spec-to {
      color: var(--accent-2); font-weight: 600;
    }
    .spec-diff .spec-arrow { color: var(--muted); margin: 0 .15rem; }
    .spec-diff .spec-tag {
      margin-left: auto;
      font-size: .7rem; text-transform: uppercase; letter-spacing: .05em;
      color: var(--muted); border: 1px solid var(--border);
      border-radius: 999px; padding: 0 .5rem;
    }
    .spec-diff .spec-new .spec-tag { color: var(--accent-2); border-color: var(--accent-2); }
    .spec-diff .spec-same { opacity: .6; }
    .spec-diff .spec-same .spec-tag { opacity: .8; }
    /* Upgrade-plan detail row */
    .plan-table td { vertical-align: top; }
    .plan-table .kind-pill {
      text-transform: uppercase; font-weight: 600; color: var(--accent);
      border-color: var(--accent);
    }
    .plan-row td { padding-bottom: .3rem; }
    .plan-row .upgrade-to {
      font-size: .95rem;
      display: flex; align-items: baseline; flex-wrap: wrap; gap: .35rem;
    }
    .upgrade-link {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px dashed transparent;
    }
    .upgrade-link:hover { border-bottom-color: var(--accent); text-decoration: none; }
    .upgrade-link:focus-visible {
      outline: 2px solid var(--accent); outline-offset: 2px;
      border-radius: 2px;
    }
    .upgrade-link .external-icon {
      font-size: .7em; margin-left: .15rem; color: var(--muted);
      vertical-align: .15em;
    }
    .upgrade-link:hover .external-icon { color: var(--accent); }
    .pill.source-pill {
      text-transform: uppercase; font-weight: 600; letter-spacing: .05em;
      color: var(--accent-2); border-color: var(--accent-2);
      background: transparent;
    }
    .plan-row .replaces {
      color: var(--muted); font-size: .78rem; margin-top: .15rem;
    }
    .plan-row .uplift-pos { color: var(--accent-2); font-weight: 600; }
    .plan-row .uplift-zero { color: var(--muted); }
    .plan-detail > td {
      background: var(--panel-2);
      border-bottom: 2px solid var(--border);
      padding: .4rem 1rem 1rem;
    }
    .detail-grid {
      display: grid; gap: 1rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 760px) {
      .detail-grid { grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr); }
    }
    .detail-title {
      color: var(--muted); font-size: .72rem; text-transform: uppercase;
      letter-spacing: .08em; margin: 0 0 .35rem;
    }
    .detail-block .rationale {
      margin: 0; font-size: .92rem; line-height: 1.55; color: var(--text);
      white-space: pre-wrap;
    }
    footer {
      text-align: center; color: var(--muted); font-size: .8rem; padding: 1.5rem 1rem;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body x-data="{
        budget: 800, workload: 'gaming_1440p', strategy: 'multi',
        zip: '98101', loaded: false
      }">

  <header class="topbar">
    <span class="logo">PC</span>
    <h1>PC Upgrade Advisor</h1>
    <span class="muted">{{ disclaimer }}</span>
  </header>

  <main>

    <!-- ========== Inventory card ========== -->
    <section class="card">
      <div class="card-head">
        <h2>Inventory</h2>
        <span class="badge">local snapshot</span>
      </div>
      <div class="card-body">
        <p class="muted" x-show="!loaded">
          Click <b>Detect this PC</b> to inspect your actual hardware with the
          native probe (WMI on Windows, lshw on Linux, system_profiler on
          macOS). Or load the snapshot the server was started with.
        </p>
        <div class="actions">
          <button class="primary"
                  hx-post="/htmx/detect" hx-target="#inventory" hx-indicator="#inv-busy"
                  hx-confirm="Run the native hardware probe on this machine?"
                  @htmx:after-request="loaded = true">
            Detect this PC
          </button>
          <button class="ghost"
                  hx-get="/htmx/inventory" hx-target="#inventory" hx-indicator="#inv-busy"
                  @htmx:after-request="loaded = true">
            Load configured snapshot
          </button>
          <span id="inv-busy" class="htmx-indicator">working...</span>
        </div>
        <div id="inventory"></div>
      </div>
    </section>

    <!-- ========== Recommend card ========== -->
    <section class="card">
      <div class="card-head">
        <h2>Upgrade plan</h2>
        <span class="badge">budget-constrained</span>
      </div>
      <div class="card-body">
        <div class="form-row" style="flex-direction:column; gap:8px;">
          <div id="market-status" class="muted" style="font-size:13px;">
            {%- if market_age_days is not none %}
              Market source: <b>{{ market_source }}</b>.
              {% if market_is_stale -%}
                <span style="color:#c87a00;"><b>Stale</b> ({{ market_age_days }} days old - consider refreshing).</span>
              {%- elif market_age_days == 0 -%}
                Just refreshed.
              {%- else -%}
                {{ market_age_days }} day(s) old.
              {%- endif %}
            {%- else %}
              No market data loaded yet.
            {%- endif %}
          </div>
          <div class="actions">
            <button type="button" class="ghost"
                    hx-post="/htmx/market/refresh"
                    hx-target="#market-status"
                    hx-indicator="#market-busy"
                    hx-confirm="Refresh prices from live retailer APIs? Requires API keys to be configured.">
              Refresh prices
            </button>
            <span id="market-busy" class="htmx-indicator">refreshing...</span>
          </div>
        </div>
        <form @submit.prevent>
          <div class="form-row">
            <label for="budget">Budget (USD)</label>
            <input id="budget" type="number" min="100" step="50"
                   x-model.number="budget">
          </div>
          <div class="form-row">
            <label for="workload">Workload</label>
            <select id="workload" x-model="workload">
              <option value="gaming_1080p">Gaming - 1080p</option>
              <option value="gaming_1440p">Gaming - 1440p</option>
              <option value="gaming_4k">Gaming - 4K</option>
              <option value="productivity">Productivity</option>
              <option value="content_creation">Content creation</option>
              <option value="ml_workstation">ML workstation</option>
            </select>
          </div>
          <div class="form-row">
            <label for="strategy">Strategy</label>
            <select id="strategy" x-model="strategy">
              <option value="greedy">Greedy - fast baseline</option>
              <option value="ilp">ILP - optimal under linear constraints</option>
              <option value="multi">Multi-objective - perf / power / noise</option>
            </select>
          </div>
          <div class="form-row">
            <label for="zip">ZIP (tax)</label>
            <input id="zip" type="text" pattern="\d{5}" maxlength="5"
                   placeholder="optional" x-model="zip">
          </div>
          <div class="actions">
            <button type="button" class="primary"
                    hx-get="/htmx/plan" hx-target="#plan" hx-indicator="#plan-busy"
                    :hx-vals="JSON.stringify({budget:budget, workload:workload, strategy:strategy})">
              Recommend
            </button>
            <button type="button" class="ghost"
                    hx-get="/htmx/quote" hx-target="#plan" hx-indicator="#plan-busy"
                    :hx-vals="JSON.stringify({budget:budget, workload:workload, strategy:strategy, zip:zip})">
              Generate quote
            </button>
            <span id="plan-busy" class="htmx-indicator">computing...</span>
          </div>
        </form>
      </div>
    </section>

    <!-- ========== Plan / Quote results ========== -->
    <section class="card col-span-2">
      <div class="card-head">
        <h2>Results</h2>
        <span class="badge">plan + quote</span>
      </div>
      <div class="card-body">
        <div id="plan">
          <p class="muted">Configure a budget above and hit <b>Recommend</b>.</p>
        </div>
      </div>
    </section>

    <section class="card col-span-2">
      <div class="card-head">
        <h2>Raw JSON</h2>
        <span class="badge">/api/inventory</span>
      </div>
      <div class="card-body">
        <details>
          <summary>Expand the full inventory payload</summary>
          <pre id="inventory-json" class="json muted"
               hx-get="/api/inventory" hx-trigger="toggle from:closest details once"
               hx-swap="innerHTML"></pre>
        </details>
      </div>
    </section>

  </main>

  <footer>
    <span>Local-first. No telemetry. See <a href="https://github.com/example/pc-upgrade-advisor">source</a>.</span>
  </footer>
</body>
</html>
