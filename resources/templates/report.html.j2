<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>PC Upgrade Advisor - {{ snapshot.id }}</title>
  <style>
    body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; color: #1a1a1a;
           max-width: 960px; margin: 2rem auto; padding: 0 1rem; line-height: 1.45; }
    h1 { border-bottom: 2px solid #333; padding-bottom: .3rem; }
    h2 { margin-top: 2rem; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #ccc; padding: .4rem .6rem; text-align: left; }
    th { background: #f3f3f3; }
    .muted { color: #666; }
    .tag { display: inline-block; padding: .05rem .4rem; border-radius: 3px;
           background: #eef; font-size: .85rem; }
  </style>
</head>
<body>
  <h1>PC Upgrade Advisor report</h1>
  <p class="muted">
    Snapshot <strong>{{ snapshot.id }}</strong> captured {{ snapshot.captured_at }}
    on <strong>{{ snapshot.os_info.family }} {{ snapshot.os_info.version }}</strong>.
  </p>

  <h2>Current components</h2>
  <table>
    <thead>
      <tr><th>Kind</th><th>Vendor</th><th>Model</th><th>Key specs</th></tr>
    </thead>
    <tbody>
    {% for c in snapshot.components %}
      <tr>
        <td><span class="tag">{{ c.kind.value }}</span></td>
        <td>{{ c.vendor }}</td>
        <td>{{ c.model }}</td>
        <td class="muted">
          {% for k, v in c.specs.items() %}{{ k }}={{ v }}{% if not loop.last %}, {% endif %}{% endfor %}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if snapshot.benchmarks %}
  <h2>Benchmarks</h2>
  <table>
    <thead>
      <tr><th>Component</th><th>Metric</th><th>Value</th><th>Unit</th><th>Env</th></tr>
    </thead>
    <tbody>
    {% for b in snapshot.benchmarks %}
      <tr>
        <td>{{ b.component_id }}</td>
        <td>{{ b.metric }}</td>
        <td>{{ "%.2f"|format(b.value) }}</td>
        <td>{{ b.unit }}</td>
        <td class="muted">{{ b.env_hash }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if deprecations %}
  <h2>Deprecation & support warnings</h2>
  <ul>
    {% for d in deprecations %}
      <li>{{ d }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  <p class="muted" style="margin-top:2rem; font-size:.85rem">
    Generated by PC Upgrade Advisor. No components were modified during this scan.
  </p>
</body>
</html>
